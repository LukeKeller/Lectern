# Lectern — environment (single-user)
NODE_ENV=development

# --- BFF (aggregator backend-for-frontend) ---
BFF_HOST=127.0.0.1
BFF_PORT=8787
BFF_PUBLIC_URL=http://localhost:8787

# Bearer token the PWA/Android client presents to /api. Generate a random value.
LECTERN_API_TOKEN=change-me

# Local dev identity. In production this comes from the Ynh-User SSO header.
LECTERN_DEV_USER=luke

# --- Glue Postgres (Lectern's own state) ---
DATABASE_URL=postgres://lectern:lectern@localhost:5433/lectern

# --- MiniFlux (RSS backend) ---
MINIFLUX_URL=http://localhost:8088
MINIFLUX_API_TOKEN=

# --- Readeck (read-later backend) ---
READECK_URL=http://localhost:8089
READECK_API_TOKEN=

# --- Web Push notifications (optional) ---
# Enable only with a VAPID keypair. Generate one with:
#   node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k.publicKey+'\n'+k.privateKey)"
LECTERN_ENABLE_PUSH=
LECTERN_VAPID_PUBLIC_KEY=
LECTERN_VAPID_PRIVATE_KEY=
LECTERN_VAPID_SUBJECT=mailto:admin@example.com

# --- Content discovery worker (optional) ---
# Base URL of the discovery worker; the BFF POSTs /run here to trigger a run.
DISCOVERY_URL=http://127.0.0.1:8790
# Bearer token the BFF presents to the discovery worker's trigger endpoint.
DISCOVERY_TOKEN=
