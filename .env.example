# Lectern — environment (single-user)
NODE_ENV=development

# --- BFF (aggregator backend-for-frontend) ---
BFF_HOST=127.0.0.1
BFF_PORT=8787
BFF_PUBLIC_URL=http://localhost:8787

# Bearer token the PWA/Android client presents to /api. Generate a random value.
LECTERN_API_TOKEN=change-me

# Local dev identity. In production this comes from the Ynh-User SSO header.
LECTERN_DEV_USER=luke

# --- Glue Postgres (Lectern's own state) ---
DATABASE_URL=postgres://lectern:lectern@localhost:5433/lectern

# --- MiniFlux (RSS backend) ---
MINIFLUX_URL=http://localhost:8088
MINIFLUX_API_TOKEN=

# --- Readeck (read-later backend) ---
READECK_URL=http://localhost:8089
READECK_API_TOKEN=

# --- Newsletter ingestion via IMAP (optional) ---
# Reads a dedicated newsletter mailbox into the library. Empty IMAP_HOST = off.
# IMAP_HOST must match the mail server's certificate name (your mail domain, or
# 127.0.0.1 for Proton Bridge) — never "localhost". IMAP_SECURE=1 is implicit TLS
# (port 993); 0 connects plain and upgrades via STARTTLS (143, or Bridge's 1143).
# See docs/newsletters.md.
LECTERN_ENABLE_EMAIL=
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_SECURE=1
# Comma-separated From addresses to skip. Case-insensitive, exact-match.
IMAP_EXCLUDE_SENDERS=
# One-off backfill: normally only mail arriving after Lectern starts watching is
# ingested. Set to 1, let one poll run, then set it back to 0.
IMAP_INGEST_BACKLOG=0
# Extra CA bundle for a self-signed IMAP certificate (Proton Bridge's is
# CN=127.0.0.1). Adds a trusted root — verification stays ON. Leave empty for a
# publicly-trusted mail server; Node ignores an empty value. A nonexistent path
# makes Node warn on every handshake.
NODE_EXTRA_CA_CERTS=

# --- Web Push notifications (optional) ---
# Enable only with a VAPID keypair. Generate one with:
#   node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k.publicKey+'\n'+k.privateKey)"
LECTERN_ENABLE_PUSH=
LECTERN_VAPID_PUBLIC_KEY=
LECTERN_VAPID_PRIVATE_KEY=
LECTERN_VAPID_SUBJECT=mailto:admin@example.com

# --- Content discovery worker (optional) ---
# Base URL of the discovery worker; the BFF POSTs /run here to trigger a run.
DISCOVERY_URL=http://127.0.0.1:8790
# Bearer token the BFF presents to the discovery worker's trigger endpoint.
DISCOVERY_TOKEN=
