#!/bin/bash

source /usr/share/yunohost/helpers

# Custom apply: after the panel writes the IMAP settings, derive the enable flag
# (host present => on), re-render .env from the templates, and restart so the
# change takes effect immediately — no upgrade or SSH needed.
ynh_app_config_apply() {
    _ynh_app_config_apply

    imap_host="$(ynh_app_setting_get --key=imap_host)"
    imap_port="$(ynh_app_setting_get --key=imap_port)"
    imap_port="${imap_port:-993}"
    enable_email=""
    if [ -n "$imap_host" ]; then
        enable_email="1"
    fi
    ynh_app_setting_set --key=imap_port --value="$imap_port"
    ynh_app_setting_set --key=enable_email --value="$enable_email"

    imap_user="$(ynh_app_setting_get --key=imap_user)"
    imap_password="$(ynh_app_setting_get --key=imap_password)"

    # The panel's boolean fields are auto-bound to these settings by
    # _ynh_app_config_apply above and always yield "1"/"0"; re-default them
    # anyway so an install that predates the panel fields still renders .env.
    imap_secure="$(ynh_app_setting_get --key=imap_secure)"
    imap_secure="${imap_secure:-1}"
    ynh_app_setting_set --key=imap_secure --value="$imap_secure"

    imap_ingest_backlog="$(ynh_app_setting_get --key=imap_ingest_backlog)"
    imap_ingest_backlog="${imap_ingest_backlog:-0}"
    ynh_app_setting_set --key=imap_ingest_backlog --value="$imap_ingest_backlog"

    # Must never be empty: the BFF's schema default only fires on an ABSENT var,
    # an empty IMAP_MAILBOX stays empty and no mailbox opens.
    imap_mailbox="$(ynh_app_setting_get --key=imap_mailbox)"
    imap_mailbox="${imap_mailbox:-INBOX}"
    ynh_app_setting_set --key=imap_mailbox --value="$imap_mailbox"

    # Extra CA bundle for a self-signed IMAP cert (Proton Bridge). Empty is the
    # normal case and Node ignores an empty value entirely, so no defaulting.
    node_extra_ca_certs="$(ynh_app_setting_get --key=node_extra_ca_certs)"

    # Text-to-speech: the panel field is auto-bound to the kokoro_base_url setting
    # by _ynh_app_config_apply above; default it if the panel cleared it so the
    # .env render below never sees an empty base URL.
    kokoro_base_url="$(ynh_app_setting_get --key=kokoro_base_url)"
    kokoro_base_url="${kokoro_base_url:-http://127.0.0.1:8880}"
    ynh_app_setting_set --key=kokoro_base_url --value="$kokoro_base_url"

    # Text-to-speech: the panel field is auto-bound to the piper_base_url setting
    # by _ynh_app_config_apply above; default it if the panel cleared it so the
    # .env render below never sees an empty base URL.
    piper_base_url="$(ynh_app_setting_get --key=piper_base_url)"
    piper_base_url="${piper_base_url:-http://127.0.0.1:5000}"
    ynh_app_setting_set --key=piper_base_url --value="$piper_base_url"

    ynh_config_add --template=".env" --destination="$install_dir/.env"
    chmod 400 "$install_dir/.env"
    chown "$app:$app" "$install_dir/.env"

    ynh_systemctl --service="$app" --action="restart"
}

ynh_app_config_run "$1"
