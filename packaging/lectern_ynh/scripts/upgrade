#!/bin/bash

source /usr/share/yunohost/helpers

ynh_script_progression "Stopping Lectern..."
ynh_systemctl --service="$app" --action="stop"

#=================================================
# UPGRADE APP FILES (prebuilt artifact)
#=================================================
ynh_script_progression "Upgrading Lectern files..."
ynh_safe_rm "$install_dir/server"
ynh_safe_rm "$install_dir/web"
cp -a "$YNH_APP_BASEDIR/sources/server" "$install_dir/server"
cp -a "$YNH_APP_BASEDIR/sources/web" "$install_dir/web"
chmod -R o-rwx "$install_dir"
chown -R "$app:$app" "$install_dir"

#=================================================
# APPLY DATABASE MIGRATIONS
#=================================================
# Migrations are written to be re-runnable (CREATE TABLE / ADD COLUMN IF NOT
# EXISTS), so applying the full set on every upgrade is safe and idempotent.
ynh_script_progression "Applying database migrations..."
for sqlfile in "$YNH_APP_BASEDIR/sources/migrations/"*.sql; do
    ynh_psql_db_shell <"$sqlfile"
done
ynh_psql_db_shell <<EOF
GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO "$db_user";
GRANT ALL PRIVILEGES ON ALL SEQUENCES IN SCHEMA public TO "$db_user";
EOF

#=================================================
# RECONFIGURE
#=================================================
ynh_script_progression "Reconfiguring..."

# Newsletter mailbox (optional). Initialize defaults so upgrades from installs
# that predate IMAP support don't fail .env rendering on an unset variable, and
# persist them so the values are durable across future upgrades.
imap_host="${imap_host:-}"
imap_port="${imap_port:-993}"
imap_user="${imap_user:-}"
imap_password="${imap_password:-}"
imap_exclude_senders="${imap_exclude_senders:-}"
enable_email="${enable_email:-}"
ynh_app_setting_set --key=imap_host --value="$imap_host"
ynh_app_setting_set --key=imap_port --value="$imap_port"
ynh_app_setting_set --key=imap_user --value="$imap_user"
ynh_app_setting_set --key=imap_password --value="$imap_password"
ynh_app_setting_set --key=imap_exclude_senders --value="$imap_exclude_senders"
ynh_app_setting_set --key=enable_email --value="$enable_email"

# Text-to-speech (optional). Backfill the Kokoro-FastAPI base URL with its default
# so upgrades from installs that predate TTS support don't fail .env rendering on
# an unset variable, and persist it so the value is durable across future upgrades.
kokoro_base_url="${kokoro_base_url:-http://127.0.0.1:8880}"
ynh_app_setting_set --key=kokoro_base_url --value="$kokoro_base_url"

ynh_config_add --template=".env" --destination="$install_dir/.env"
chmod 400 "$install_dir/.env"
chown "$app:$app" "$install_dir/.env"

ynh_config_add_nginx
ynh_config_add_systemd

# Refresh the app logo (admin UI renders applogos/$app.png directly).
cp -f "$YNH_APP_BASEDIR/conf/lectern.png" /usr/share/yunohost/applogos/lectern.png 2>/dev/null || true

ynh_script_progression "Starting Lectern..."
ynh_systemctl --service="$app" --action="start" --wait_until="Lectern BFF listening" --log_path="systemd"

ynh_script_progression "Upgrade of $app completed"
