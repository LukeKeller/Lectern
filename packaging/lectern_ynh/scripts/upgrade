#!/bin/bash

source /usr/share/yunohost/helpers

ynh_script_progression "Stopping Lectern..."
ynh_systemctl --service="$app" --action="stop"
# The discovery worker may not exist yet (upgrade from a pre-discovery install).
systemctl stop "$app-discovery" 2>/dev/null || true

#=================================================
# UPGRADE APP FILES (prebuilt artifact)
#=================================================
ynh_script_progression "Upgrading Lectern files..."
ynh_safe_rm "$install_dir/server"
ynh_safe_rm "$install_dir/web"
ynh_safe_rm "$install_dir/discovery"
cp -a "$YNH_APP_BASEDIR/sources/server" "$install_dir/server"
cp -a "$YNH_APP_BASEDIR/sources/web" "$install_dir/web"
cp -a "$YNH_APP_BASEDIR/sources/discovery" "$install_dir/discovery"
chmod -R o-rwx "$install_dir"
chown -R "$app:$app" "$install_dir"

#=================================================
# APPLY DATABASE MIGRATIONS
#=================================================
# Migrations are written to be re-runnable (CREATE TABLE / ADD COLUMN IF NOT
# EXISTS), so applying the full set on every upgrade is safe and idempotent.
ynh_script_progression "Applying database migrations..."
for sqlfile in "$YNH_APP_BASEDIR/sources/migrations/"*.sql; do
    ynh_psql_db_shell <"$sqlfile"
done
ynh_psql_db_shell <<EOF
GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO "$db_user";
GRANT ALL PRIVILEGES ON ALL SEQUENCES IN SCHEMA public TO "$db_user";
EOF

#=================================================
# RECONFIGURE
#=================================================
ynh_script_progression "Reconfiguring..."

# Newsletter mailbox (optional). Initialize defaults so upgrades from installs
# that predate IMAP support don't fail .env rendering on an unset variable, and
# persist them so the values are durable across future upgrades.
imap_host="${imap_host:-}"
imap_port="${imap_port:-993}"
imap_user="${imap_user:-}"
imap_password="${imap_password:-}"
imap_exclude_senders="${imap_exclude_senders:-}"
enable_email="${enable_email:-}"
# These four used to be hardcoded in the .env template, so they had no setting to
# restore from and no way to be configured at all. They are placeholders now, so
# back them off with the same defaults a fresh install writes. imap_mailbox must
# never end up empty — the BFF's zod default only fires on an ABSENT var, an
# empty one stays empty. node_extra_ca_certs stays empty unless the operator
# points it at a self-signed IMAP cert (Node ignores an empty value).
imap_secure="${imap_secure:-1}"
imap_mailbox="${imap_mailbox:-INBOX}"
imap_ingest_backlog="${imap_ingest_backlog:-0}"
node_extra_ca_certs="${node_extra_ca_certs:-}"
ynh_app_setting_set --key=imap_host --value="$imap_host"
ynh_app_setting_set --key=imap_port --value="$imap_port"
ynh_app_setting_set --key=imap_user --value="$imap_user"
ynh_app_setting_set --key=imap_password --value="$imap_password"
ynh_app_setting_set --key=imap_mailbox --value="$imap_mailbox"
ynh_app_setting_set --key=imap_secure --value="$imap_secure"
ynh_app_setting_set --key=imap_ingest_backlog --value="$imap_ingest_backlog"
ynh_app_setting_set --key=imap_exclude_senders --value="$imap_exclude_senders"
ynh_app_setting_set --key=node_extra_ca_certs --value="$node_extra_ca_certs"
ynh_app_setting_set --key=enable_email --value="$enable_email"

# Text-to-speech (optional). Backfill the Kokoro-FastAPI base URL with its default
# so upgrades from installs that predate TTS support don't fail .env rendering on
# an unset variable, and persist it so the value is durable across future upgrades.
kokoro_base_url="${kokoro_base_url:-http://127.0.0.1:8880}"
ynh_app_setting_set --key=kokoro_base_url --value="$kokoro_base_url"

# Text-to-speech (optional). Backfill the Piper base URL with its default so
# upgrades from installs that predate Piper support don't fail .env rendering on
# an unset variable, and persist it so the value is durable across future upgrades.
piper_base_url="${piper_base_url:-http://127.0.0.1:5000}"
ynh_app_setting_set --key=piper_base_url --value="$piper_base_url"

# Content discovery worker. Generate the BFF->worker shared secret on the first
# upgrade that predates discovery support, then persist it (durable across upgrades).
discovery_token="${discovery_token:-}"
if [ -z "$discovery_token" ]; then
    discovery_token=$(ynh_string_random --length=48)
fi
ynh_app_setting_set --key=discovery_token --value="$discovery_token"
# The `discovery` port resource provisions $port_discovery; default it defensively
# so the .env render never hard-errors on an unset placeholder.
port_discovery="${port_discovery:-8790}"

# Web Push (optional). Generate a VAPID keypair on the first upgrade that predates
# push support, then persist it so it's durable (re-keying would invalidate every
# existing browser subscription). Existing keys are preserved as-is.
vapid_public_key="${vapid_public_key:-}"
vapid_private_key="${vapid_private_key:-}"
if [ -z "$vapid_public_key" ] || [ -z "$vapid_private_key" ]; then
    ynh_script_progression "Generating Web Push (VAPID) keys..."
    vapid_keys=$(cd "$install_dir/server" && node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k.publicKey+'\n'+k.privateKey)")
    vapid_public_key=$(echo "$vapid_keys" | sed -n '1p')
    vapid_private_key=$(echo "$vapid_keys" | sed -n '2p')
fi
vapid_subject="${vapid_subject:-mailto:admin@$domain}"
enable_push="${enable_push:-1}"
ynh_app_setting_set --key=vapid_public_key --value="$vapid_public_key"
ynh_app_setting_set --key=vapid_private_key --value="$vapid_private_key"
ynh_app_setting_set --key=vapid_subject --value="$vapid_subject"
ynh_app_setting_set --key=enable_push --value="$enable_push"

ynh_config_add --template=".env" --destination="$install_dir/.env"
chmod 400 "$install_dir/.env"
chown "$app:$app" "$install_dir/.env"

ynh_config_add_nginx
ynh_config_add_systemd

# Discovery worker unit (idempotent; also registers it on the first upgrade that
# introduces discovery). `yunohost service add` is idempotent.
ynh_config_add_systemd --service="$app-discovery" --template="systemd-discovery.service"
yunohost service add "$app-discovery" --description="Lectern discovery worker" --log="/var/log/$app/$app-discovery.log"

# Refresh the app logo (admin UI renders applogos/$app.png directly).
cp -f "$YNH_APP_BASEDIR/conf/lectern.png" /usr/share/yunohost/applogos/lectern.png 2>/dev/null || true

ynh_script_progression "Starting Lectern..."
ynh_systemctl --service="$app" --action="start" --wait_until="Lectern BFF listening" --log_path="systemd"
ynh_systemctl --service="$app-discovery" --action="start"

ynh_script_progression "Upgrade of $app completed"
