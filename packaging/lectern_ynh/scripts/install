#!/bin/bash

source /usr/share/yunohost/helpers

#=================================================
# GENERATE THE APP API TOKEN
#=================================================
# Bearer token the PWA/Android client presents to /api. Stored in app settings
# so it survives upgrades and is re-rendered into .env each time.
lectern_api_token=$(ynh_string_random --length=48)
ynh_app_setting_set --key=lectern_api_token --value="$lectern_api_token"

# Persist the backend config as settings. Password-type install questions are
# NOT auto-saved, so without this the upgrade script can't re-render .env.
ynh_app_setting_set --key=miniflux_url --value="$miniflux_url"
ynh_app_setting_set --key=miniflux_token --value="$miniflux_token"
ynh_app_setting_set --key=readeck_url --value="$readeck_url"
ynh_app_setting_set --key=readeck_token --value="$readeck_token"

# Newsletter mailbox (optional). Persist as settings so the upgrade script can
# re-render .env. Enable ingestion only when an IMAP host was provided; default
# the port to 993 (implicit TLS).
imap_port=993
enable_email=""
if [ -n "${imap_host:-}" ]; then
    enable_email="1"
fi
ynh_app_setting_set --key=imap_host --value="${imap_host:-}"
ynh_app_setting_set --key=imap_port --value="$imap_port"
ynh_app_setting_set --key=imap_user --value="${imap_user:-}"
ynh_app_setting_set --key=imap_password --value="${imap_password:-}"
ynh_app_setting_set --key=imap_exclude_senders --value="${imap_exclude_senders:-}"
ynh_app_setting_set --key=enable_email --value="$enable_email"

# Text-to-speech (optional). Persist the Kokoro-FastAPI base URL as a setting so
# the .env template renders and upgrades can re-render it. Defaults to the local
# Docker sibling container; configurable later from the config panel.
kokoro_base_url="${kokoro_base_url:-http://127.0.0.1:8880}"
ynh_app_setting_set --key=kokoro_base_url --value="$kokoro_base_url"

# Text-to-speech (optional). Persist the Piper base URL as a setting so the .env
# template renders and upgrades can re-render it. Piper is a lightweight CPU-only
# local TTS engine the operator runs themselves; defaults to the local sibling
# service on port 5000; configurable later from the config panel.
piper_base_url="${piper_base_url:-http://127.0.0.1:5000}"
ynh_app_setting_set --key=piper_base_url --value="$piper_base_url"

# Content discovery worker. Shared secret the BFF presents when triggering a run
# on the sibling worker. Persist as a setting so it survives upgrades and is
# re-rendered into .env each time (both services read the same value).
discovery_token=$(ynh_string_random --length=48)
ynh_app_setting_set --key=discovery_token --value="$discovery_token"

#=================================================
# INSTALL APP FILES (prebuilt artifact)
#=================================================
ynh_script_progression "Installing Lectern files..."

mkdir -p "$install_dir"
cp -a "$YNH_APP_BASEDIR/sources/server" "$install_dir/server"
cp -a "$YNH_APP_BASEDIR/sources/web" "$install_dir/web"
cp -a "$YNH_APP_BASEDIR/sources/discovery" "$install_dir/discovery"
chmod -R o-rwx "$install_dir"
chown -R "$app:$app" "$install_dir"

#=================================================
# GENERATE THE WEB PUSH VAPID KEYPAIR
#=================================================
# Web Push needs a VAPID keypair (public key sent to the browser to subscribe,
# private key signs the pushes). Generate it once with the bundled web-push lib
# now that node_modules is in place, and persist it as settings so it survives
# upgrades (re-keying would invalidate every existing browser subscription).
ynh_script_progression "Generating Web Push (VAPID) keys..."
vapid_keys=$(cd "$install_dir/server" && node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k.publicKey+'\n'+k.privateKey)")
vapid_public_key=$(echo "$vapid_keys" | sed -n '1p')
vapid_private_key=$(echo "$vapid_keys" | sed -n '2p')
vapid_subject="mailto:admin@$domain"
enable_push="1"
ynh_app_setting_set --key=vapid_public_key --value="$vapid_public_key"
ynh_app_setting_set --key=vapid_private_key --value="$vapid_private_key"
ynh_app_setting_set --key=vapid_subject --value="$vapid_subject"
ynh_app_setting_set --key=enable_push --value="$enable_push"

#=================================================
# DATABASE SCHEMA
#=================================================
ynh_script_progression "Applying the database schema..."
for sqlfile in "$YNH_APP_BASEDIR/sources/migrations/"*.sql; do
    ynh_psql_db_shell <"$sqlfile"
done

# ynh_psql_db_shell runs as the postgres admin, so the tables it just created are
# owned by postgres. Grant the app's DB user access (it connects via DATABASE_URL).
ynh_psql_db_shell <<EOF
GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO "$db_user";
GRANT ALL PRIVILEGES ON ALL SEQUENCES IN SCHEMA public TO "$db_user";
EOF

#=================================================
# CONFIGURATION
#=================================================
ynh_script_progression "Adding configuration..."
ynh_config_add --template=".env" --destination="$install_dir/.env"
chmod 400 "$install_dir/.env"
chown "$app:$app" "$install_dir/.env"

#=================================================
# APP LOGO
#=================================================
# Drop the app logo into YunoHost's logo folder. The admin UI renders
# applogos/$app.png directly (the documented "$app.png" customization trick),
# so this needs no catalog entry. Lock-free file copy — safe inside the script.
cp -f "$YNH_APP_BASEDIR/conf/lectern.png" /usr/share/yunohost/applogos/lectern.png 2>/dev/null || true

#=================================================
# SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Adding system configurations..."
mkdir -p "/var/log/$app"
chown -R "$app:$app" "/var/log/$app"

ynh_config_add_nginx
ynh_config_add_systemd
yunohost service add "$app" --description="Lectern reader" --log="/var/log/$app/$app.log"

# Discovery worker: its own systemd unit (localhost-only sibling service).
ynh_config_add_systemd --service="$app-discovery" --template="systemd-discovery.service"
yunohost service add "$app-discovery" --description="Lectern discovery worker" --log="/var/log/$app/$app-discovery.log"

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting Lectern..."
ynh_systemctl --service="$app" --action="start" --wait_until="Lectern BFF listening" --log_path="systemd"
ynh_systemctl --service="$app-discovery" --action="start"

ynh_script_progression "Installation of $app completed"
