NODE_ENV=production
BFF_HOST=127.0.0.1
BFF_PORT=__PORT__
BFF_PUBLIC_URL=https://__DOMAIN__
LECTERN_API_TOKEN=__LECTERN_API_TOKEN__
LECTERN_DEV_USER=
LECTERN_WEB_DIR=__INSTALL_DIR__/web
LECTERN_ENABLE_JOBS=1
DATABASE_URL=postgresql://__DB_USER__:__DB_PWD__@localhost:5432/__DB_NAME__
MINIFLUX_URL=__MINIFLUX_URL__
MINIFLUX_API_TOKEN=__MINIFLUX_TOKEN__
MINIFLUX_BASIC=
READECK_URL=__READECK_URL__
READECK_API_TOKEN=__READECK_TOKEN__
# DO NOT HAND-EDIT THIS FILE ON THE SERVER. Every `yunohost app upgrade` (and
# every config-panel apply) re-renders it from this template using the app's
# stored settings, silently discarding local edits. The settings ARE the source
# of truth — change them with `yunohost app config set lectern <key> <value>`
# or from the app's config panel in the admin UI.
#
# Newsletter ingestion (optional). Leave IMAP_HOST empty to disable. Point at a
# dedicated mailbox the user subscribes newsletters to (its own IMAP login).
#
# IMAP_HOST must match the name on the mail server's certificate. For a normal
# remote mail server that means the mail domain (e.g. mail.example.com), NOT
# "localhost" — a TLS connection to "localhost" fails the certificate name
# check. For a local gateway with a self-signed cert the rule is the same, it
# just resolves differently: Proton Bridge issues its cert for CN=127.0.0.1, so
# 127.0.0.1 is the correct host there and "localhost" would still fail.
#
# IMAP_SECURE=1 means implicit TLS from the first byte (port 993). Set it to 0
# for a STARTTLS/plain port (143, or Proton Bridge's 1143) — the connection is
# still upgraded to TLS via STARTTLS when the server advertises it.
LECTERN_ENABLE_EMAIL=__ENABLE_EMAIL__
IMAP_HOST=__IMAP_HOST__
IMAP_PORT=__IMAP_PORT__
IMAP_USER=__IMAP_USER__
IMAP_PASSWORD=__IMAP_PASSWORD__
IMAP_MAILBOX=__IMAP_MAILBOX__
IMAP_SECURE=__IMAP_SECURE__
# Comma-separated From addresses to skip (e.g. internal/system mail that lands in
# this mailbox). Case-insensitive, exact-match. Empty = ingest everything.
IMAP_EXCLUDE_SENDERS=__IMAP_EXCLUDE_SENDERS__
# Backfill escape hatch. Normally Lectern only ever ingests mail that arrives
# AFTER it starts watching: on the first run — and after any UIDVALIDITY reset,
# which happens on every Proton Bridge restart and whenever IMAP_HOST/IMAP_USER
# changes — it seeds its UID cursor to the mailbox's current high-water mark and
# ingests nothing that poll (the ingestion log says so). Set to 1 for a one-off
# import of the existing back catalogue, then set it back to 0.
IMAP_INGEST_BACKLOG=__IMAP_INGEST_BACKLOG__
# Extra CA bundle for Node's TLS trust store. Needed only when the IMAP server
# presents a self-signed certificate that no public CA vouches for — Proton
# Bridge is the common case (its cert is self-signed with CN=127.0.0.1 and lives
# at ~/.config/protonmail/bridge-v3/cert.pem; copy it somewhere the app user can
# read and point this at that copy). Certificate verification stays fully ON:
# this ADDS a trusted root, it does not disable checking, so a wrong host or an
# expired cert still fails. Leave it EMPTY when the mail server has a normal
# publicly-trusted certificate — Node ignores an empty value entirely. Do not
# point it at a nonexistent path: Node then prints "Ignoring extra certs from
# ..., load failed" on every TLS handshake.
NODE_EXTRA_CA_CERTS=__NODE_EXTRA_CA_CERTS__
# Text-to-speech via the optional self-hosted Kokoro-FastAPI sibling service. The
# BFF appends OpenAI-compatible paths (/v1/audio/speech, /v1/audio/voices) to this
# base URL. The default works with the recommended Docker run command:
#   docker run -d --name kokoro-tts --restart unless-stopped \
#     -p 127.0.0.1:8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:latest
KOKORO_BASE_URL=__KOKORO_BASE_URL__
# Text-to-speech via the optional self-hosted Piper sibling service (lightweight,
# CPU-only — much lighter than Kokoro). The BFF POSTs to /synthesize and reads
# /voices on this base URL, then transcodes Piper's WAV output to mp3 (ffmpeg must
# be installed). The default works with the recommended run command:
#   python3 -m piper.http_server -m en_US-lessac-medium --data-dir <dir> \
#     --host 127.0.0.1 --port 5000
PIPER_BASE_URL=__PIPER_BASE_URL__
# Web Push notifications. The VAPID keypair is generated at install (and persisted
# across upgrades) by the package; the SPA fetches the public key to subscribe.
LECTERN_ENABLE_PUSH=__ENABLE_PUSH__
LECTERN_VAPID_PUBLIC_KEY=__VAPID_PUBLIC_KEY__
LECTERN_VAPID_PRIVATE_KEY=__VAPID_PRIVATE_KEY__
LECTERN_VAPID_SUBJECT=__VAPID_SUBJECT__
# Content discovery worker (the sibling __APP__-discovery service, apps/discovery).
# One shared .env: the BFF reads DISCOVERY_URL/DISCOVERY_TOKEN to trigger runs; the
# worker reads DISCOVERY_HOST/PORT + LECTERN_API_URL/LECTERN_API_TOKEN to call back
# into the BFF over loopback. DISCOVERY_TOKEN authenticates BFF->worker triggers.
# Fetch sources, topics, schedule cadence, and API keys are managed in-app (Settings
# -> Discover); DISCOVERY_ENABLE just controls whether the worker's cron ticks.
DISCOVERY_URL=http://127.0.0.1:__PORT_DISCOVERY__
DISCOVERY_TOKEN=__DISCOVERY_TOKEN__
DISCOVERY_HOST=127.0.0.1
DISCOVERY_PORT=__PORT_DISCOVERY__
LECTERN_API_URL=http://127.0.0.1:__PORT__/api/v1
DISCOVERY_ENABLE=1
DISCOVERY_SCHEDULE=0 */6 * * *
