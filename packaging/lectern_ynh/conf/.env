NODE_ENV=production
BFF_HOST=127.0.0.1
BFF_PORT=__PORT__
BFF_PUBLIC_URL=https://__DOMAIN__
LECTERN_API_TOKEN=__LECTERN_API_TOKEN__
LECTERN_DEV_USER=
LECTERN_WEB_DIR=__INSTALL_DIR__/web
LECTERN_ENABLE_JOBS=1
DATABASE_URL=postgresql://__DB_USER__:__DB_PWD__@localhost:5432/__DB_NAME__
MINIFLUX_URL=__MINIFLUX_URL__
MINIFLUX_API_TOKEN=__MINIFLUX_TOKEN__
MINIFLUX_BASIC=
READECK_URL=__READECK_URL__
READECK_API_TOKEN=__READECK_TOKEN__
# Newsletter ingestion (optional). Leave IMAP_HOST empty to disable. Point at a
# dedicated mailbox the user subscribes newsletters to (its own IMAP login).
# Use the mail server's cert hostname (the mail domain), NOT "localhost" — a TLS
# connection to "localhost" fails the certificate name check.
LECTERN_ENABLE_EMAIL=__ENABLE_EMAIL__
IMAP_HOST=__IMAP_HOST__
IMAP_PORT=__IMAP_PORT__
IMAP_USER=__IMAP_USER__
IMAP_PASSWORD=__IMAP_PASSWORD__
IMAP_MAILBOX=INBOX
IMAP_SECURE=1
# Comma-separated From addresses to skip (e.g. internal/system mail that lands in
# this mailbox). Case-insensitive, exact-match. Empty = ingest everything.
IMAP_EXCLUDE_SENDERS=__IMAP_EXCLUDE_SENDERS__
